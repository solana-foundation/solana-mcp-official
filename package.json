{
  "name": "solana-mcp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "gen:sources": "node scripts/build-sources.mjs",
    "start": "node build/server/cloudrun.js",
    "dev:local": "node scripts/build-sources.mjs && tsx watch server/cloudrun.ts",
    "build": "node scripts/build-sources.mjs && tsc -p tsconfig.json",
    "test": "pnpm test:integration",
    "test:integration": "pnpm gen:sources && vitest run tests/integration.test.ts tests/unit/",
    "test:e2e": "pnpm gen:sources && vitest run tests/e2e.test.ts",
    "test:coverage": "pnpm gen:sources && vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm gen:sources && pnpm typecheck:ts && pnpm typecheck:vitest",
    "typecheck:ts": "tsc --noEmit",
    "typecheck:vitest": "vitest --run --typecheck.only",
    "inspector": "npx -y @modelcontextprotocol/inspector npx mcp-remote http://localhost:3000/mcp",
    "audit:security": "pnpm audit --audit-level=high"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "hono@<4.12.14": ">=4.12.14",
      "hono@<4.12.16": ">=4.12.16",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<=10.1.0": ">=10.1.1",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^17.3.1",
    "mcp-handler": "1.1.0",
    "tree-sitter-rust": "^0.24.0",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solana/prettier-config-solana": "^0.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "js-yaml": "^4.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.3"
  }
}
